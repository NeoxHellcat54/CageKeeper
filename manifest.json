<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="theme-color" content="#020203" />
  <meta name="description" content="CageKeeper - a dark self-lock PWA for local chastity lock sessions." />
  <title>CageKeeper</title>
  <link rel="manifest" href="manifest.json" />
  <link rel="icon" href="assets/icon-192.png" />
  <link rel="apple-touch-icon" href="assets/icon-192.png" />
  <link rel="stylesheet" href="style.css" />
</head>
<body>
  <div class="ambient" aria-hidden="true"></div>
  <div class="grain" aria-hidden="true"></div>

  <div class="app-shell">
    <header class="app-header">
      <div class="brand-block">
        <div class="brand-mark" aria-hidden="true">
          <span></span>
        </div>
        <div>
          <p class="overline">CageKeeper v0.1</p>
          <h1>CageKeeper</h1>
        </div>
      </div>

      <div id="statusPill" class="status-pill">No active lock</div>
    </header>

    <nav class="tab-bar" aria-label="Main navigation">
      <button class="nav-btn active" data-screen="dashboard">Vault</button>
      <button class="nav-btn" data-screen="start">Seal</button>
      <button class="nav-btn" data-screen="extensions">Extensions</button>
      <button class="nav-btn" data-screen="archive">Archive</button>
      <button class="nav-btn" data-screen="settings">Settings</button>
    </nav>

    <main>
      <section id="dashboard" class="screen active-screen">
        <div class="vault-layout">
          <section class="hero-panel">
            <div class="hero-copy">
              <p class="overline">Vault status</p>
              <h2 id="lockTitle">The cage is open.</h2>
              <p id="lockSubtitle" class="muted">Seal a self-lock when you are ready.</p>
            </div>

            <div class="time-grid" aria-live="polite" aria-label="Countdown timer">
              <div class="time-cell">
                <strong id="daysCell">--</strong>
                <span>Days</span>
              </div>
              <div class="time-cell">
                <strong id="hoursCell">--</strong>
                <span>Hours</span>
              </div>
              <div class="time-cell">
                <strong id="minutesCell">--</strong>
                <span>Minutes</span>
              </div>
              <div class="time-cell">
                <strong id="secondsCell">--</strong>
                <span>Seconds</span>
              </div>
            </div>

            <div id="timerCaption" class="timer-caption">No active timer</div>

            <div id="activeMeta" class="meta-grid hidden">
              <div>
                <span>Started</span>
                <strong id="startedAt">—</strong>
              </div>
              <div>
                <span>Release</span>
                <strong id="releaseAt">—</strong>
              </div>
              <div>
                <span>Duration</span>
                <strong id="durationText">—</strong>
              </div>
              <div>
                <span>Extensions</span>
                <strong id="activeExtensions">—</strong>
              </div>
            </div>

            <div class="action-row">
              <button id="completeLockBtn" class="primary-btn hidden">Archive Completed Lock</button>
            </div>
          </section>

          <aside class="side-stack">
            <section id="dailyCheckinPanel" class="module-panel">
              <div class="module-header">
                <div>
                  <p class="overline pink">Extension</p>
                  <h3>Daily Check-In</h3>
                </div>
                <div id="dailyModuleBadge" class="mini-badge">Enabled</div>
              </div>
              <p id="dailyModuleStatus" class="muted">No active lock is waiting for a check-in.</p>
              <button id="checkInBtn" class="ghost-btn" disabled>Check In</button>
            </section>

            <section class="panel compact-panel">
              <p class="overline gold">Recent activity</p>
              <div id="recentLog" class="timeline compact"></div>
            </section>
          </aside>
        </div>
      </section>

      <section id="start" class="screen">
        <section class="panel wide-panel">
          <p class="overline purple">Seal</p>
          <h2>Choose the range. CageKeeper chooses the time.</h2>
          <p class="muted">The first version is intentionally simple: one local self-lock, a random duration, and optional modules.</p>

          <form id="startForm" class="form-stack">
            <label>
              Lock label
              <input id="lockName" type="text" maxlength="40" placeholder="Example: Weekend lock" autocomplete="off" />
            </label>

            <div class="form-grid">
              <label>
                Minimum
                <input id="minDuration" type="number" min="1" step="1" value="12" required />
              </label>
              <label>
                Maximum
                <input id="maxDuration" type="number" min="1" step="1" value="48" required />
              </label>
            </div>

            <label>
              Unit
              <select id="durationUnit">
                <option value="hours">Hours</option>
                <option value="days">Days</option>
              </select>
            </label>

            <div class="module-choice">
              <div>
                <strong>Daily Check-In extension</strong>
                <span id="startDailySummary">Enabled</span>
              </div>
              <button class="text-btn" type="button" data-jump="extensions">Edit extension</button>
            </div>

            <button class="primary-btn wide" type="submit">Seal Lock</button>
          </form>
        </section>
      </section>

      <section id="extensions" class="screen">
        <section class="panel wide-panel">
          <p class="overline pink">Extensions</p>
          <h2>Optional modules, not core rules.</h2>
          <p class="muted">CageKeeper starts with one modifiable extension. Later, this is where Pillory, Mercy Court, dice rolls, and time modifiers can live.</p>
        </section>

        <section class="extension-card">
          <div class="extension-topline">
            <div>
              <p class="overline gold">Installed extension</p>
              <h3>Daily Check-In</h3>
              <p class="muted">Adds one check-in action per local day while a lock is active. For now, missed days are logged only.</p>
            </div>
            <label class="toggle-row">
              <input id="dailyEnabled" type="checkbox" />
              <span class="switch" aria-hidden="true"></span>
              Enabled
            </label>
          </div>

          <form id="extensionForm" class="form-stack module-settings">
            <label>
              Button text
              <input id="dailyButtonText" type="text" maxlength="36" />
            </label>

            <label>
              Success message
              <input id="dailySuccessText" type="text" maxlength="70" />
            </label>

            <label>
              Missed-day log text
              <input id="dailyMissedText" type="text" maxlength="70" />
            </label>

            <label>
              Missed-day effect
              <select id="dailyMissedMode">
                <option value="log">Log only</option>
              </select>
            </label>

            <button class="primary-btn" type="submit">Save Extension</button>
          </form>
        </section>
      </section>

      <section id="archive" class="screen">
        <div class="stat-grid">
          <div class="stat-tile">
            <span>Completed locks</span>
            <strong id="statCompleted">0</strong>
          </div>
          <div class="stat-tile">
            <span>Total locked time</span>
            <strong id="statTotalTime">0h</strong>
          </div>
          <div class="stat-tile">
            <span>Check-ins</span>
            <strong id="statCheckins">0</strong>
          </div>
          <div class="stat-tile">
            <span>Missed days</span>
            <strong id="statMissed">0</strong>
          </div>
        </div>

        <section class="panel">
          <p class="overline gold">Timeline</p>
          <h2>Everything CageKeeper remembers.</h2>
          <div id="fullLog" class="timeline"></div>
        </section>
      </section>

      <section id="settings" class="screen">
        <section class="panel wide-panel">
          <p class="overline purple">Settings</p>
          <h2>Local save data.</h2>
          <p class="muted">Everything is stored on this device/browser. Export before clearing browser data or moving devices.</p>

          <div class="settings-actions">
            <button id="exportBtn" class="ghost-btn">Export Save</button>
            <label class="file-btn">
              Import Save
              <input id="importInput" type="file" accept="application/json,.json" />
            </label>
            <button id="resetBtn" class="danger-btn">Reset App</button>
          </div>
        </section>

        <section class="panel compact-panel">
          <p class="overline gold">Build notes</p>
          <p class="muted">This build keeps CageKeeper self-lock only. The extension system is now separated from the core lock so future modules can plug in cleanly.</p>
        </section>
      </section>
    </main>

    <div id="toast" class="toast" role="status" aria-live="polite"></div>
  </div>

  <script src="app.js"></script>
</body>
</html>
